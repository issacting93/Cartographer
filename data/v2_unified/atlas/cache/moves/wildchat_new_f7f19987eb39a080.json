    "role": "assistant",
    "content": "\u0412\u043e\u0442 \u043f\u0440\u0438\u043c\u0435\u0440 \u043a\u043e\u0434\u0430 \u043d\u0430 Python 3 \u0434\u043b\u044f \u0441\u043e\u0437\u0434\u0430\u043d\u0438\u044f \u0442\u0435\u043b\u0435\u0433\u0440\u0430\u043c-\u0431\u043e\u0442\u0430 \u0432 Telebot, \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u0440\u0435\u0430\u043b\u0438\u0437\u0443\u0435\u0442 \u0442\u0440\u0435\u0431\u0443\u0435\u043c\u044b\u0435 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044f:\n\n```python\nimport telebot\nfrom telebot import types\nimport os\n\n# \u0412\u0441\u0442\u0430\u0432\u044c\u0442\u0435 \u0441\u044e\u0434\u0430 \u0442\u043e\u043a\u0435\u043d \u0432\u0430\u0448\u0435\u0433\u043e \u0431\u043e\u0442\u0430, \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u0432\u044b \u043f\u043e\u043b\u0443\u0447\u0438\u043b\u0438 \u0432 BotFather\nTOKEN = 'your_token_here'\n\n# \u0421\u043e\u0437\u0434\u0430\u0435\u043c \u043d\u043e\u0432\u044b\u0439 \u043e\u0431\u044a\u0435\u043a\u0442 \u0431\u043e\u0442\u0430 \u0441 \u0443\u043a\u0430\u0437\u0430\u043d\u043d\u044b\u043c \u0442\u043e\u043a\u0435\u043d\u043e\u043c\nbot = telebot.TeleBot(TOKEN)\n\n# \u041a\u043d\u043e\u043f\u043a\u0438 \u0434\u043b\u044f \u0441\u043e\u043e\u0431\u0449\u0435\u043d\u0438\u044f Text1\nbutton1 = types.InlineKeyboardButton('\u041a\u043d\u043e\u043f\u043a\u04301', callback_data='button1')\nbutton2 = types.InlineKeyboardButton('\u041a\u043d\u043e\u043f\u043a\u04302', callback_data='button2')\nbutton3 = types.InlineKeyboardButton('\u041a\u043d\u043e\u043f\u043a\u04303', callback_data='button3')\nkeyboard = types.InlineKeyboardMarkup(row_width=3)\nkeyboard.add(button1, button2, button3)\n\n# \u041a\u043d\u043e\u043f\u043a\u0438 \u0434\u043b\u044f \u0430\u043d\u043a\u0435\u0442\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u044f\nquestion1 = types.InlineKeyboardButton('\u0412\u043e\u043f\u0440\u043e\u0441 1', callback_data='question1')\nquestion2 = types.InlineKeyboardButton('\u0412\u043e\u043f\u0440\u043e\u0441 2', callback_data='question2')\nquestion3 = types.InlineKeyboardButton('\u0412\u043e\u043f\u0440\u043e\u0441 3', callback_data='question3')\nquestionnaire_keyboard = types.InlineKeyboardMarkup(row_width=1)\nquestionnaire_keyboard.add(question1, question2, question3)\n\n\n@bot.message_handler(commands=['start'])\ndef start_command(message):\n    # \u041e\u0442\u043f\u0440\u0430\u0432\u043b\u044f\u0435\u043c \u0441\u043e\u043e\u0431\u0449\u0435\u043d\u0438\u0435 Text1 \u0441 \u043a\u043d\u043e\u043f\u043a\u0430\u043c\u0438\n    bot.send_message(message.chat.id, 'Text1', reply_markup=keyboard)\n\n\n@bot.callback_query_handler(func=lambda call: True)\ndef callback_handler(call):\n    if call.data == 'button1':\n        bot.send_message(call.message.chat.id, 'Text2')\n    elif call.data == 'button2':\n        bot.send_message(call.message.chat.id, 'Link1')\n    elif call.data == 'button3':\n        # \u041d\u0430\u0447\u0438\u043d\u0430\u0435\u043c \u0430\u043d\u043a\u0435\u0442\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435\n        bot.send_message(call.message.chat.id, '\u0412\u043e\u043f\u0440\u043e\u0441 1', reply_markup=questionnaire_keyboard)\n\n\n@bot.message_handler(commands=['about'])\ndef about_command(message):\n    # \u041e\u0442\u043f\u0440\u0430\u0432\u043b\u044f\u0435\u043c \u0441\u043e\u043e\u0431\u0449\u0435\u043d\u0438\u0435 Text4 \u0438 \u0438\u0437\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u0438\u0435\n    photo = open('your_photo.jpg', 'rb')\n    bot.send_photo(message.chat.id, photo)\n    bot.send_message(message.chat.id, 'Text4')\n\n\nif __name__ == '__main__':\n    # \u0423\u0441\u0442\u0430\u043d\u043e\u0432\u043a\u0430 webhook\n    # \u041f\u043e\u0434\u0440\u043e\u0431\u043d\u0435\u0435: https://core.telegram.org/bots/api#setwebhook\n    WEBHOOK_URL_BASE = os.getenv('WEBHOOK_URL_BASE')\n    WEBHOOK_URL_PATH = '/webhook/'\n    WEBHOOK_URL = f\"{WEBHOOK_URL_BASE}{WEBHOOK_URL_PATH}\"\n\n    # \u0423\u0434\u0430\u043b\u044f\u0435\u043c \u043f\u0440\u0435\u0434\u044b\u0434\u0443\u0449\u0438\u0435 \u0432\u0435\u0431\u0445\u0443\u043a\u0438 (\u0435\u0441\u043b\u0438 \u043e\u043d\u0438 \u0431\u044b\u043b\u0438)\n    bot.remove_webhook()\n\n    # \u0423\u0441\u0442\u0430\u043d\u043e\u0432\u043a\u0430 \u0432\u0435\u0431\u0445\u0443\u043a\u0430\n    bot.set_webhook(url=WEBHOOK_URL)\n\n    # \u0417\u0430\u043f\u0443\u0441\u043a \u0441\u0435\u0440\u0432\u0435\u0440\u0430 \u0434\u043b\u044f \u043e\u0431\u0440\u0430\u0431\u043e\u0442\u043a\u0438 \u0432\u0435\u0431\u0445\u0443\u043a\u043e\u0432 \u0432 \u043e\u0442\u0434\u0435\u043b\u044c\u043d\u043e\u043c \u043f\u043e\u0442\u043e\u043a\u0435\n    bot.polling(none_stop=True, interval=0, timeout=20)\n```\n\n\u0412\u0430\u043c \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u043e \u0437\u0430\u043c\u0435\u043d\u0438\u0442\u044c \u0441\u0442\u0440\u043e\u043a\u0443 `your_token_here` \u043d\u0430 \u0442\u043e\u043a\u0435\u043d \u0432\u0430\u0448\u0435\u0433\u043e \u0431\u043e\u0442\u0430 Telegram; \u0437\u0430\u0433\u0440\u0443\u0437\u0438\u0442\u044c \u0441\u0432\u043e\u044e \u0444\u043e\u0442\u043e\u0433\u0440\u0430\u0444\u0438\u044e \u0441 \u0438\u043c\u0435\u043d\u0435\u043c `your_photo.jpg` \u0432 \u0434\u0438\u0440\u0435\u043a\u0442\u043e\u0440\u0438\u044e \u0441 \u044d\u0442\u0438\u043c \u0441\u043a\u0440\u0438\u043f\u0442\u043e\u043c; \u0443\u0441\u0442\u0430\u043d\u043e\u0432\u0438\u0442\u044c `WEBHOOK_URL_BASE` \u0440\u0430\u0432\u043d\u044b\u043c \u0430\u0434\u0440\u0435\u0441\u0443 \u0432\u0430\u0448\u0435\u0433\u043e \u0441\u0435\u0440\u0432\u0435\u0440\u0430 (\u043d\u0430\u043f\u0440\u0438\u043c\u0435\u0440, `https://example.com`); \u0438 \u043d\u0430\u0441\u0442\u0440\u043e\u0438\u0442\u044c \u0441\u043e\u043e\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0443\u044e\u0449\u0438\u0435 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044f (\u043d\u0430\u043f\u0440\u0438\u043c\u0435\u0440, \u0437\u0430\u043c\u0435\u043d\u0438\u0442\u044c `Text1`, `Text2`, `Link1` 